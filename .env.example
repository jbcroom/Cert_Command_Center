# ─── Supabase ────────────────────────────────────────────────────────────────
# Your Supabase project URL
# Where to find: supabase.com → your project → Settings → API → Project URL
VITE_SUPABASE_URL=https://your-project.supabase.co

# Public anon key — safe to expose in the frontend bundle
# Where to find: supabase.com → your project → Settings → API → anon / public
VITE_SUPABASE_ANON_KEY=your-anon-key

# Service role key — SERVER-SIDE ONLY. Never expose in frontend or commit to git.
# Used by migration and seed scripts only (scripts/ directory).
# Where to find: supabase.com → your project → Settings → API → service_role
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── Anthropic ───────────────────────────────────────────────────────────────
# Required for all AI features: cert Q&A chat, study guide generation,
# study plan generation, exam debrief, and flashcard generation.
# IMPORTANT: this key is used server-side only (Vercel Functions in api/).
# Do NOT prefix with VITE_ — that would expose it to the browser bundle.
# Where to find: console.anthropic.com → API Keys → Create key
ANTHROPIC_API_KEY=your-anthropic-api-key

# ─── Email digest (optional) ─────────────────────────────────────────────────
# Required only if you want the weekly email digest feature.
# Free tier at resend.com covers personal use (100 emails/day, 3,000/month).
# On free tier, emails can only be sent to your Resend account email address
# until you verify a custom domain.
# Where to find: resend.com → API Keys → Create API Key
# Format: starts with re_
RESEND_API_KEY=your-resend-api-key

# ─── Dev only — never add to Vercel ──────────────────────────────────────────
# Bypasses the auth gate locally so you can develop without signing in.
# Vite hardcodes import.meta.env.DEV=false in production builds,
# so this bypass is completely unreachable in any deployed build.
VITE_DEV_BYPASS_AUTH=true
